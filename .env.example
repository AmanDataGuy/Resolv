# --- Phase 0/1: local, no GCP required ---
GEMINI_API_KEY=
# Groq is used automatically instead of Gemini when GROQ_API_KEY is set — see
# config.get_model(). GROQ_API_KEY_2 / _3 are optional extra keys: if the active
# key hits a rate limit mid-run, agents/runner_utils.py rotates to the next one
# and retries automatically (see config.rotate_groq_key()).
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

SEND_MODE=draft                          # "draft" = log only | "live" = real sending
AUTO_RESOLVE_CONFIDENCE_THRESHOLD=0.85
AUTO_RESOLVE_MAX_RISK_USD=10000.0

OPS_MANAGER_PHONE=+1xxxxxxxxxx
OPS_MANAGER_EMAIL=ops@yourcompany.com

# --- Phase 2+: GCP (leave blank until Phase 2) ---
GCP_PROJECT_ID=
GCP_REGION=us-central1
FIRESTORE_DATABASE=(default)
GCS_BUCKET=

# --- Phase 3+: fine-tuning ---
HF_TOKEN=
DRAFTER_MODEL_ENDPOINT=gemini-2.0-flash
MIN_TRAIN_SCORE=80.0
MIN_SFT_SCORE=65.0
WEEKLY_FINE_TUNE_MIN_EXAMPLES=50

# --- Phase 4: voice ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
DEEPGRAM_API_KEY=
PUBLIC_BASE_URL=

# --- Comms (Phase 1: Slack optional, email stays in draft mode) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=resolv@yourdomain.com
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
